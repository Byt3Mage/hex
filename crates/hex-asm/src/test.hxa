fn fib(1, 1, 5):
    loadi R1, $0 // a = 0
    loadi R2, $1 // b = 1
    loadi R3, $0 // loop_guard = 0
@fib_loop:
    jeq   R0, R3, @fib_end
    add   R4, R1, R2 // R4 = a + b
    copy  R1, R2 // a = b
    copy  R2, R4 // b = a + b
    subi  R0, R0, $1 // n -= 1
    jmp   @fib_loop
@fib_end:
    copy R0, R1
    ret

fn test(0, 1, 4):
    loadi R0, $0 // sum = 0
    loadi R1, $0 // i = 0
    loadi R2, $10 // max = 20
@test_loop:
    jugt R1, R2, @test_end
    copy R3, R1  // copy i to R3
    call R3, fib // fib(i)
    add  R0, R0, R3 // sum += fib(i)
    addi R1, R1, $1 // i++
    jmp  @test_loop
@test_end:
    ret
